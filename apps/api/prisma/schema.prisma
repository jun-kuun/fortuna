generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssetType {
  KOREAN_STOCK
  OVERSEAS_STOCK
  REAL_ESTATE
  DEPOSIT
  GOLD
  OTHER
}

enum TransactionType {
  BUY
  SELL
}

enum Currency {
  KRW
  USD
}

model Asset {
  id           String        @id @default(cuid())
  name         String
  type         AssetType
  currency     Currency      @default(KRW)
  ticker       String?
  createdAt    DateTime      @default(now())
  holding      Holding?
  transactions Transaction[]
}

model Holding {
  id             String    @id @default(cuid())
  assetId        String    @unique
  asset          Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  quantity       Float     @default(0)
  avgCostPrice   Float     @default(0)
  currentPrice   Float     @default(0)
  priceUpdatedAt DateTime?
  updatedAt      DateTime  @updatedAt
}

model Transaction {
  id      String          @id @default(cuid())
  assetId String
  asset   Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  type    TransactionType
  quantity Float
  price   Float
  fee     Float           @default(0)
  date    DateTime
  memo    String?
  createdAt DateTime      @default(now())
}

model StrategyProfile {
  id          String   @id @default(cuid())
  name        String
  allocations Json     // { "KOREAN_STOCK": 40, "OVERSEAS_STOCK": 30, ... } 합계 100
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InvestmentGoal {
  id           String   @id @default(cuid())
  name         String
  targetAmount Float
  targetDate   DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
