generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssetType {
  KOREAN_STOCK
  OVERSEAS_STOCK
  REAL_ESTATE
  DEPOSIT
  GOLD
  OTHER
}

enum TransactionType {
  BUY
  SELL
}

enum Currency {
  KRW
  USD
}

model Asset {
  id            String        @id @default(cuid())
  name          String
  type          AssetType
  subType       String?
  currency      Currency      @default(KRW)
  ticker        String?
  interestRate  Float?        // 연이율 (%), 예적금용
  maturityDate  DateTime?     // 만기일, 예적금용
  createdAt     DateTime      @default(now())
  deletedAt     DateTime?
  holding       Holding?
  transactions  Transaction[]
  priceHistory  PriceHistory[]
}

model Holding {
  id             String    @id @default(cuid())
  assetId        String    @unique
  asset          Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  quantity       Float     @default(0)
  avgCostPrice   Float     @default(0)
  currentPrice   Float     @default(0)
  priceUpdatedAt DateTime?
  updatedAt      DateTime  @updatedAt
}

model Transaction {
  id      String          @id @default(cuid())
  assetId String
  asset   Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  type    TransactionType
  quantity Float
  price   Float
  fee     Float           @default(0)
  date    DateTime
  memo    String?
  createdAt DateTime      @default(now())
}

model PriceHistory {
  id         String   @id @default(cuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  price      Float
  recordedAt DateTime @default(now())

  @@index([assetId, recordedAt])
}

model StrategyProfile {
  id          String   @id @default(cuid())
  name        String
  allocations Json     // { "KOREAN_STOCK": 40, "OVERSEAS_STOCK": 30, ... } 합계 100
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InvestmentGoal {
  id           String   @id @default(cuid())
  name         String
  targetAmount Float
  targetDate   DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
